{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Course Service — SLO",
  "uid": "course-service-slo",
  "tags": ["eduvn", "slo"],
  "schemaVersion": 39,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "RPS",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_request_duration_seconds_count{service=\"course-service\"}[1m]))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (5xx)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_request_duration_seconds_count{service=\"course-service\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_request_duration_seconds_count{service=\"course-service\"}[5m])), 1e-9)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"course-service\"}[5m])) by (le))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Pods up",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(up{service=\"course-service\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"course-service\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"course-service\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"course-service\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate by status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_request_duration_seconds_count{service=\"course-service\"}[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU usage vs limit",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"eduvn\",pod=~\"course-service.*\",container!=\"\"}[5m]))",
          "legendFormat": "cpu cores used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(kube_pod_container_resource_limits{namespace=\"eduvn\",pod=~\"course-service.*\",resource=\"cpu\"})",
          "legendFormat": "cpu limit"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory working set vs limit",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(container_memory_working_set_bytes{namespace=\"eduvn\",pod=~\"course-service.*\",container!=\"\"})",
          "legendFormat": "mem used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(kube_pod_container_resource_limits{namespace=\"eduvn\",pod=~\"course-service.*\",resource=\"memory\"})",
          "legendFormat": "mem limit"
        }
      ]
    }
  ]
}
